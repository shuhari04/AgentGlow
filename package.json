{
  "name": "agentglow",
  "version": "0.1.0",
  "description": "Agent-aware RGB animations for QMK keyboards",
  "type": "module",
  "bin": { "agentglow": "dist/src/cli.js" },
  "files": ["dist", "profiles", "hooks", "firmware", "docs", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/test/*.test.js",
    "check": "npm run lint && npm test"
  },
  "engines": { "node": ">=20" },
  "license": "MIT",
  "repository": { "type": "git", "url": "git+https://github.com/shuhari04/AgentGlow.git" },
  "keywords": ["qmk", "rgb", "codex", "claude-code", "keyboard", "raw-hid"],
  "dependencies": { "node-hid": "^3.2.0" },
  "devDependencies": { "@types/node": "^22.15.0", "typescript": "^5.8.3" }
}
